                    <!-- ICERIK ANALIZI SEKMESI -->
                    <TabItem Header="Icerik Analizi" Style="{StaticResource SeoTab}">
                        <Grid Background="#0A0E1A">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                                <StackPanel Margin="24,18,12,24">

                                    <TextBlock Text="OKUNABILIRLIK ANALIZI" Foreground="#5A6A85"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                                    <Border Background="#1A2235" CornerRadius="10" Padding="20,16" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="72" Height="72" CornerRadius="36" Background="#0D1525"
                                                    BorderBrush="#A855F7" BorderThickness="3" Margin="0,0,20,0">
                                                <TextBlock x:Name="TxtReadScore" Text="--" FontSize="24" FontWeight="Black"
                                                           Foreground="#A855F7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtReadLevel" Text="Analiz bekleniyor"
                                                           Foreground="#E8EDF5" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TxtReadDetail" Text=""
                                                           Foreground="#5A6A85" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,8"/>
                                                <ProgressBar x:Name="ReadProgress" Height="6" Maximum="100" Value="0"
                                                             Background="#1E2D45" Foreground="#A855F7">
                                                    <ProgressBar.Template>
                                                        <ControlTemplate TargetType="ProgressBar">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                                <Border x:Name="PART_Track">
                                                                    <Border x:Name="PART_Indicator"
                                                                            Background="{TemplateBinding Foreground}"
                                                                            CornerRadius="3" HorizontalAlignment="Left"/>
                                                                </Border>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </ProgressBar.Template>
                                                </ProgressBar>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="METIN / HTML ORANI" Foreground="#5A6A85"
                                               FontSize="10" FontWeight="Bold" Margin="0,14,0,12"/>
                                    <Border Background="#1A2235" CornerRadius="10" Padding="18,14" Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Metin/HTML orani" Foreground="#5A6A85" FontSize="13" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="TxtTextRatioPct" Text="0%"
                                                           Foreground="#00D4FF" FontSize="18" FontWeight="Bold"/>
                                            </Grid>
                                            <Border Background="#1E2D45" Height="10" CornerRadius="5">
                                                <Border x:Name="TextRatioBar" Background="#00D4FF" CornerRadius="5"
                                                        HorizontalAlignment="Left" Width="0"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Border Background="#0D1525" CornerRadius="5" Padding="10,5" Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="TxtHtmlSize" Text="0 KB" Foreground="#5A6A85" FontSize="12"/>
                                                        <TextBlock Text=" HTML" Foreground="#2A3A55" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="#0D1525" CornerRadius="5" Padding="10,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="TxtTextSize" Text="0 KB" Foreground="#00D4FF" FontSize="12"/>
                                                        <TextBlock Text=" Metin" Foreground="#2A3A55" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="ROBOTS.TXT / SITEMAP / GZIP" Foreground="#5A6A85"
                                               FontSize="10" FontWeight="Bold" Margin="0,14,0,12"/>
                                    <ItemsControl x:Name="RobotsItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A2235" CornerRadius="8" Padding="16,12" Margin="0,0,0,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Foreground="#5A6A85" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#E8EDF5"
                                                                   FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        <Border Grid.Column="2" CornerRadius="4" Background="{Binding BadgeColor}"
                                                                Padding="8,3" VerticalAlignment="Center" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="{Binding StatusFg}"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- RAKIP KARSILASTIRMA -->
                    <TabItem Header="Rakip" Style="{StaticResource SeoTab}">
                        <Grid Background="#0A0E1A">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#111827" Padding="16,10" BorderBrush="#1E2D45" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtRakipUrl" Style="{StaticResource InputStyle}"
                                             Text="https://" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" x:Name="BtnRakipAnalyze" Content="KARSILASTIR"
                                            Margin="10,0,0,0" Style="{StaticResource BtnPrimary}"
                                            Height="42" Padding="20,0" Click="BtnRakipAnalyze_Click"/>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                                <StackPanel Margin="24,18,12,24">
                                    <Border x:Name="RakipLoading" Visibility="Collapsed" Background="#1A2235"
                                            CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Rakip site analiz ediliyor..."
                                                       Foreground="#FF6B35" FontSize="13" HorizontalAlignment="Center"/>
                                            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0"
                                                         Background="#1E2D45" Foreground="#FF6B35"/>
                                        </StackPanel>
                                    </Border>
                                    <ItemsControl x:Name="CompareItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A2235" CornerRadius="8" Padding="14,11" Margin="0,0,0,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="65"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Foreground="#5A6A85"
                                                                   FontSize="12" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Margin="8,0">
                                                            <TextBlock Text="Sen" Foreground="#00D4FF"
                                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                                                            <TextBlock Text="{Binding Val1}" Foreground="#E8EDF5"
                                                                       FontSize="12" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Margin="8,0">
                                                            <TextBlock Text="Rakip" Foreground="#FF6B35"
                                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                                                            <TextBlock Text="{Binding Val2}" Foreground="#E8EDF5"
                                                                       FontSize="12" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3" CornerRadius="4" Background="{Binding WinColor}"
                                                                Padding="6,3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding Winner}" FontSize="11"
                                                                       FontWeight="Bold" Foreground="{Binding WinFg}"
                                                                       HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ANALIZ GECMISI -->
                    <TabItem Header="Gecmis" Style="{StaticResource SeoTab}">
                        <Grid Background="#0A0E1A">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#111827" Padding="16,8" BorderBrush="#1E2D45" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Analiz gecmisi (son 20 tarama)" Foreground="#5A6A85"
                                               FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="Temizle" Style="{StaticResource BtnSecondary}"
                                            Height="30" Padding="12,0" Margin="14,0,0,0"
                                            Click="BtnClearHistory_Click"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                                <StackPanel Margin="24,18,12,24">
                                    <ItemsControl x:Name="HistoryItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A2235" CornerRadius="8" Padding="16,12"
                                                        Margin="0,0,0,5" Cursor="Hand"
                                                        MouseLeftButtonUp="HistoryItem_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Url}" Foreground="#00D4FF"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding AnalysisDate}" Foreground="#5A6A85" FontSize="11"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" CornerRadius="20" Background="{Binding ScoreColor}"
                                                                Padding="14,4" Margin="12,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Score}" FontSize="14" FontWeight="Black"
                                                                       Foreground="{Binding ScoreFg}" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding Speed}"
                                                                   Foreground="#5A6A85" FontSize="12"
                                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                        <TextBlock Grid.Column="3" Text="Yeniden &gt;"
                                                                   Foreground="#2A3A55" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Kaynak Kod" Style="{StaticResource SeoTab}">
                        <Grid Background="#0A0E1A">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#111827" Padding="16,8" BorderBrush="#1E2D45" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Sayfa kaynak kodu" Foreground="#5A6A85" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="Panoya Kopyala" Style="{StaticResource BtnSecondary}"
                                            Height="30" Padding="12,0" Margin="14,0,0,0" Click="BtnCopyHtml_Click"/>
                                </StackPanel>
                            </Border>
                            <TextBox Grid.Row="1" x:Name="TxtRawHtml"
                                     Background="#0D1525" Foreground="#6A7A95"
                                     FontFamily="Consolas" FontSize="12"
                                     BorderThickness="0" Padding="16"
                                     IsReadOnly="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Visible"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsUndoEnabled="False"/>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#0D1525" BorderBrush="#1E2D45" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Foreground="#5A6A85" FontSize="12" VerticalAlignment="Center"
                           Text="Analiz etmek icin URL girin ve ANALIZ ET butonuna tiklayin."/>
                <TextBlock Grid.Column="1" Text="SEO Analyzer Pro v1.0" Foreground="#2A3A55" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>