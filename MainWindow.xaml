                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtExternalCount" Text="0" Foreground="#FF6B35" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text=" DIŞ" Foreground="#5A6A85" FontSize="12"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3" Background="#2A0510" CornerRadius="6" Padding="12,5" BorderBrush="#FF3B5C" BorderThickness="1">
