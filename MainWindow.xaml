                                                            <TextBlock Text="{Binding Src}" Foreground="#E8EDF5" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding AltText}" Foreground="#5A6A85" FontSize="11"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" CornerRadius="4" Background="{Binding AltBadgeColor}"
                                            Padding="8,3" VerticalAlignment="Center" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding AltStatus}" FontSize="11" FontWeight="Bold" Foreground="#E8EDF5"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Teknik SEO" Style="{StaticResource SeoTab}">
                        <Grid Background="#0A0E1A">
