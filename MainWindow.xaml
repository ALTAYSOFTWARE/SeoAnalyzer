<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SEO Analyzer Pro" Height="860" Width="1300"
        Background="#0A0E1A" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" MinWidth="950" MinHeight="620"
        WindowState="Maximized">
    <Window.Resources>

        <Style TargetType="Thumb" x:Key="DarkThumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" Background="#2E4060" Margin="2,1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkVertScrollBar" TargetType="ScrollBar">
            <Grid Width="12" Background="#0D1525">
                <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="0,0">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent"
                              BorderThickness="0" Opacity="0" Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent"
                              BorderThickness="0" Opacity="0" Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Template" Value="{StaticResource DarkVertScrollBar}"/>
                    <Setter Property="Width" Value="12"/>
                    <Setter Property="MinWidth" Value="12"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Height" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ScrollContentPresenter Grid.Column="0" CanContentScroll="False"
                                            CanHorizontallyScroll="False" CanVerticallyScroll="True"/>

                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                               Orientation="Vertical" Minimum="0"
                               Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                               Maximum="{Binding ScrollableHeight, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                               ViewportSize="{Binding ViewportHeight, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1525"/>
            <Setter Property="Foreground" Value="#E8EDF5"/>
            <Setter Property="BorderBrush" Value="#1E2D45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#00D4FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Height="42">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#00D4FF"/>
            <Setter Property="Foreground" Value="#0A0E1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="28,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33DDFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0099BB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#1E2D45"/>
                                <Setter Property="Foreground" Value="#5A6A85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5A6A85"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#1E2D45" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2235"/>
                                <Setter Property="Foreground" Value="#E8EDF5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#1A2235"/>
                                <Setter Property="Foreground" Value="#5A6A85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeoProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#1E2D45"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="3" HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Background" Value="#1E2D45"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="2" HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeoTab" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5A6A85"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                        BorderThickness="0,0,0,2" BorderBrush="Transparent"
                        Padding="{TemplateBinding Padding}">

                            <ContentPresenter ContentSource="Header" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>

                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#00D4FF"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E8EDF5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" BorderBrush="#1E2D45" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" Background="#00D4FF" CornerRadius="8" Margin="0,0,10,0">
                        <TextBlock Text="S" FontSize="20" FontWeight="Black" Foreground="#0A0E1A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SEO" FontSize="18" FontWeight="Black" Foreground="#E8EDF5" VerticalAlignment="Center"/>
                    <TextBlock Text="Analyzer" FontSize="18" FontWeight="Light" Foreground="#5A6A85"
                               VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Border Background="#0D1525" CornerRadius="4" Padding="7,2" Margin="10,0,0,0"
                            BorderBrush="#00D4FF" BorderThickness="1">
                        <TextBlock Text="PRO" FontSize="10" FontWeight="Bold" Foreground="#00D4FF" Height="18"/>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtUrl" Grid.Column="0" Style="{StaticResource InputStyle}"
                             Text="https://" VerticalAlignment="Center" KeyDown="TxtUrl_KeyDown"/>
                    <Button Grid.Column="1" Content="ANALIZ ET" Margin="8,0,0,0"
                            Style="{StaticResource BtnPrimary}" Click="BtnAnalyze_Click" x:Name="BtnAnalyze"/>
                    <Button Grid.Column="2" Content="Temizle" Margin="8,0,0,0"
                            Style="{StaticResource BtnSecondary}" Click="BtnClear_Click"/>
                    <Button Grid.Column="3" x:Name="BtnExport" Content="HTML Rapor" Margin="8,0,0,0"
                            Style="{StaticResource BtnSecondary}" Click="BtnExport_Click" IsEnabled="False"/>
                    <Button Grid.Column="4" x:Name="BtnExportCsv" Content="CVS" Margin="6,10,137,11"
                            Style="{StaticResource BtnSecondary}" Click="BtnExportCsv_Click" IsEnabled="False" Grid.ColumnSpan="2"/>
                    <Button Grid.Column="5" Content="Rakip Karsilastir" Margin="70,10,0,11"
                            Style="{StaticResource BtnSecondary}" Click="BtnRakip_Click"/>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SEO Skoru:" Foreground="#5A6A85" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border x:Name="ScoreBadge" Background="#1A2235" CornerRadius="22"
        Padding="18,6" BorderBrush="#1E2D45" BorderThickness="1"
        ToolTip="Bu puan tahminidir, Google algoritmasını yansıtmaz.">
                        <TextBlock x:Name="TxtScore" Text="--" FontSize="22" FontWeight="Black"
               Foreground="#5A6A85" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="295"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#111827" BorderBrush="#1E2D45" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                    <StackPanel Margin="14,10,6,4">

                        <Border x:Name="LoadingPanel" Background="#1A2235" CornerRadius="10"
                                Padding="20,14" Margin="0,4,8,8" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Analiz ediliyor..." Foreground="#00D4FF"
                                           FontSize="13" HorizontalAlignment="Center"/>
                                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0"
                                             Background="#1E2D45" Foreground="#00D4FF"/>
                                <TextBlock x:Name="TxtLoadingDetail" Text="" Foreground="#5A6A85"
                                           FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="OZET" Foreground="#5A6A85" FontSize="10"
                                   FontWeight="Bold" Margin="4,6,0,8"/>

                        <Border Background="#1A2235" CornerRadius="10" Padding="14" Margin="0,0,8,6">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Sayfa Basligi" Foreground="#5A6A85" FontSize="12" VerticalAlignment="Center"/>
                                    <Border x:Name="TitleStatusBadge" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="TitleStatus" Text="--" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="TxtTitle" Text="Analiz bekleniyor..." Foreground="#E8EDF5"
                                           FontSize="12" TextWrapping="Wrap" MaxHeight="52" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,2">
                                    <TextBlock x:Name="TxtTitleLen" Text="0 karakter" Foreground="#5A6A85" FontSize="11"/>
                                    <TextBlock Text=" - ideal: 50-60" Foreground="#2A3A55" FontSize="11"/>
                                </StackPanel>
                                <ProgressBar x:Name="TitleProgress" Style="{StaticResource SeoProgress}" Margin="0,4,0,0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1A2235" CornerRadius="10" Padding="14" Margin="0,0,8,6">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Meta Aciklama" Foreground="#5A6A85" FontSize="12" VerticalAlignment="Center"/>
                                    <Border x:Name="DescStatusBadge" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="DescStatus" Text="--" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="TxtDesc" Text="Analiz bekleniyor..." Foreground="#E8EDF5"
                                           FontSize="12" TextWrapping="Wrap" MaxHeight="70" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,2">
                                    <TextBlock x:Name="TxtDescLen" Text="0 karakter" Foreground="#5A6A85" FontSize="11"/>
                                    <TextBlock Text=" - ideal: 150-160" Foreground="#2A3A55" FontSize="11"/>
                                </StackPanel>
                                <ProgressBar x:Name="DescProgress" Style="{StaticResource SeoProgress}" Margin="0,4,0,0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="HIZLI ISTATISTIKLER" Foreground="#5A6A85" FontSize="10"
                                   FontWeight="Bold" Margin="4,10,0,8"/>
                        <Grid Margin="0,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Background="#1A2235" CornerRadius="8" Padding="10" Margin="0,0,3,5">
                                <StackPanel>
                                    <TextBlock x:Name="StatH1" Text="0" FontSize="22" FontWeight="Black" Foreground="#00D4FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="H1 Tag" Foreground="#5A6A85" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Background="#1A2235" CornerRadius="8" Padding="10" Margin="3,0,0,5">
                                <StackPanel>
                                    <TextBlock x:Name="StatH2" Text="0" FontSize="22" FontWeight="Black" Foreground="#00FF88" HorizontalAlignment="Center"/>
                                    <TextBlock Text="H2 Tag" Foreground="#5A6A85" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" Background="#1A2235" CornerRadius="8" Padding="10" Margin="0,0,3,5">
                                <StackPanel>
                                    <TextBlock x:Name="StatImages" Text="0" FontSize="22" FontWeight="Black" Foreground="#FF6B35" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Resim" Foreground="#5A6A85" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Background="#1A2235" CornerRadius="8" Padding="10" Margin="3,0,0,5">
                                <StackPanel>
                                    <TextBlock x:Name="StatLinks" Text="0" FontSize="22" FontWeight="Black" Foreground="#A855F7" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Link" Foreground="#5A6A85" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="#1A2235" CornerRadius="8" Padding="10" Margin="0,0,0,5">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StatWords" Text="0" FontSize="22" FontWeight="Black" Foreground="#FFD700" VerticalAlignment="Center"/>
                                    <StackPanel Margin="8,2,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Kelime" Foreground="#5A6A85" FontSize="11"/>
                                        <TextBlock Text="Icerik" Foreground="#2A3A55" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ICERIK OZET (detaylar Icerik Analizi sekmesinde) -->
                        <TextBlock Text="ICERIK KALITESI" Foreground="#5A6A85" FontSize="10" FontWeight="Bold" Margin="4,10,0,8"/>
                        <Border Background="#1A2235" CornerRadius="8" Padding="10" Margin="0,0,8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="StatReadability" Text="--" FontSize="20" FontWeight="Black"
                                               Foreground="#A855F7" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtReadabilityNote" Text="--" Foreground="#5A6A85"
                                               FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Okunabilirlik" Foreground="#2A3A55" FontSize="10" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StatTextRatio" Text="--" FontSize="20" FontWeight="Black"
                                               Foreground="#00D4FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Metin/HTML" Foreground="#5A6A85" FontSize="10" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="SAYFA HIZI" Foreground="#5A6A85" FontSize="10" FontWeight="Bold" Margin="4,8,0,8"/>
                        <Border Background="#1A2235" CornerRadius="8" Padding="14,12" Margin="0,0,8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" Background="#0D1525" CornerRadius="18" Margin="0,0,10,0">
                                    <TextBlock Text="ms" FontSize="11" FontWeight="Bold" Foreground="#00FF88"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtSpeed" Text="-- ms" FontSize="20" FontWeight="Bold" Foreground="#00FF88"/>
                                    <TextBlock x:Name="TxtSpeedNote" Text="Yanit suresi" Foreground="#5A6A85" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="EN COK GECEN KELIMELER" Foreground="#5A6A85" FontSize="10" FontWeight="Bold" Margin="4,8,0,8"/>
                        <Border Background="#1A2235" CornerRadius="8" Padding="12,10" Margin="0,0,8,6">
                            <ItemsControl x:Name="KeywordItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Word}" Foreground="#E8EDF5" FontSize="12" Margin="0,0,0,3"/>
                                                <ProgressBar Value="{Binding Percent}" Maximum="100"
                                                             Style="{StaticResource MiniProgress}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding CountText}"
                                                       Foreground="#5A6A85" FontSize="11"
                                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Background="#0A0E1A">
                <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#111827" BorderBrush="#1E2D45" BorderThickness="0,0,0,1">
                                    <TabPanel IsItemsHost="True" Margin="12,0"/>
                                </Border>
                                <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <TabItem Header="Genel Analiz" Style="{StaticResource SeoTab}">
                        <Grid Background="#0A0E1A">

                            <ScrollViewer x:Name="SvGenel" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                                <StackPanel Margin="24,18,12,4">
                                    <TextBlock Text="SEO KONTROL LISTESI" Foreground="#5A6A85"
                           FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                                    <ItemsControl x:Name="ChecklistItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A2235" CornerRadius="8" Padding="14,11" Margin="0,0,0,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="26" Height="26"
                                            Background="{Binding StatusColor}" CornerRadius="13">
                                                            <TextBlock Text="{Binding Icon}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{Binding BadgeText}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,8,0">
                                                            <TextBlock Text="{Binding Title}" Foreground="#E8EDF5" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Detail}" Foreground="#5A6A85" FontSize="12" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" CornerRadius="5" Background="{Binding BadgeColor}"
                                            Padding="10,3" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Badge}" FontSize="11" FontWeight="Bold" Foreground="{Binding BadgeText}"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

